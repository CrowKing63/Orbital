<Window x:Class="Orbital.ActionEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Action" Height="380" Width="480"
        Icon="Assets/orbit_logo.png"
        Background="#0A0A18"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 이름 및 아이콘 -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Button Name" FontSize="11" FontWeight="SemiBold"
                           Foreground="#5A5A90" Margin="0,0,0,6"/>
                <TextBox x:Name="NameBox"/>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Icon (Hex or Emoji)" FontSize="11" FontWeight="SemiBold"
                           Foreground="#5A5A90" Margin="0,0,0,6"/>
                <TextBox x:Name="IconBox" HorizontalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- 프롬프트 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Prompt" FontSize="11" FontWeight="SemiBold"
                           Foreground="#5A5A90"/>
                <TextBlock FontSize="11" Foreground="#3A3A6A" Margin="6,0,0,0">
                    — selected text is inserted at {text}
                </TextBlock>
            </StackPanel>
            <TextBox x:Name="PromptBox" Height="75" TextWrapping="Wrap"
                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

        <!-- 출력 방식 -->
        <StackPanel Grid.Row="2" Margin="0,0,0,14">
            <TextBlock Text="Output Mode" FontSize="11" FontWeight="SemiBold"
                       Foreground="#5A5A90" Margin="0,0,0,6"/>
            <ComboBox x:Name="ResultActionBox" SelectedIndex="0">
                <ComboBoxItem Content="Replace"    ToolTip="Replace selected text with AI result"/>
                <ComboBoxItem Content="Copy"       ToolTip="Copy AI result to clipboard"/>
                <ComboBoxItem Content="Popup"      ToolTip="Show AI result in a popup window"/>
                <ComboBoxItem Content="Browser"    ToolTip="Open Google search with selected text (no AI)"/>
                <ComboBoxItem Content="DirectCopy" ToolTip="Copy selected text to clipboard (no AI)"/>
                <ComboBoxItem Content="Cut"        ToolTip="Cut selected text (no AI)"/>
                <ComboBoxItem Content="Paste"      ToolTip="Paste clipboard content at cursor (no AI)"/>
            </ComboBox>
        </StackPanel>

        <!-- Display mode -->
        <StackPanel Grid.Row="3" Margin="0,0,0,14">
            <TextBlock Text="Button Display" FontSize="11" FontWeight="SemiBold"
                       Foreground="#5A5A90" Margin="0,0,0,6"/>
            <ComboBox x:Name="DisplayModeBox" SelectedIndex="0">
                <ComboBoxItem Content="Text + Icon" Tag="TextAndIcon"/>
                <ComboBoxItem Content="Text Only"   Tag="TextOnly"/>
                <ComboBoxItem Content="Icon Only"   Tag="IconOnly"/>
            </ComboBox>
        </StackPanel>

        <!-- 옵션 -->
        <StackPanel Grid.Row="4" Margin="0,0,0,14">
            <CheckBox x:Name="RequiresSelectionCheck" Content="Requires selected text to run" 
                      Foreground="#A0A0C0" FontSize="11" IsChecked="True"/>
        </StackPanel>

        <!-- 버튼 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Width="82" Margin="0,0,8,0"
                    Style="{StaticResource PrimaryButton}"
                    IsDefault="True" Click="Ok_Click"/>
            <Button Content="Cancel" Width="82"
                    IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
