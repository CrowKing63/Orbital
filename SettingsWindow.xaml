<Window x:Class="Orbital.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orbital Settings" Height="660" Width="640"
        Icon="Assets/orbit_logo.png"
        Background="{DynamicResource WindowBgBrush}"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- Scrollable content (title + all panels) -->
            <RowDefinition Height="*"/>
            <!-- Bottom buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

        <!-- ── 타이틀 ── -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
            <Ellipse Width="10" Height="10" Margin="0,0,9,0" VerticalAlignment="Center">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#FF00D4FF" Offset="0"/>
                        <GradientStop Color="#FF7080FF" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <DropShadowEffect Color="#00D4FF" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/>
                </Ellipse.Effect>
            </Ellipse>
            <TextBlock Text="Orbital" FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource TitleFgBrush}" VerticalAlignment="Center"/>
            <TextBlock Text="  Settings" FontSize="16" FontWeight="Light"
                       Foreground="{DynamicResource SubtitleFgBrush}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ── API Settings panel ── -->
        <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="10"
                BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Margin="0,0,0,16" Padding="16,14">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="2" Opacity="0.3"/>
            </Border.Effect>
            <StackPanel>
                <!-- 섹션 헤더 -->
                <TextBlock Text="API Settings" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource LabelFgBrush}" Margin="0,0,0,12"/>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 제공자 -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,10">
                        <TextBlock Text="Provider" FontSize="11" Foreground="{DynamicResource LabelFgBrush}" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ProviderBox" SelectionChanged="ProviderBox_SelectionChanged">
                            <ComboBoxItem Tag="openai"     Content="OpenAI"/>
                            <ComboBoxItem Tag="openrouter" Content="OpenRouter"/>
                            <ComboBoxItem Tag="custom"     Content="Custom"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- 모델 -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,10">
                        <TextBlock Text="Model" FontSize="11" Foreground="{DynamicResource LabelFgBrush}" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ModelBox" IsEditable="True" IsTextSearchEnabled="False"/>
                    </StackPanel>

                    <!-- Base URL -->
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,10">
                        <TextBlock Text="API Base URL" FontSize="11" Foreground="{DynamicResource LabelFgBrush}" Margin="0,0,0,5"/>
                        <TextBox x:Name="BaseUrlBox"/>
                    </StackPanel>

                    <!-- API 키 -->
                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,6">
                        <TextBlock Text="API Key" FontSize="11" Foreground="{DynamicResource LabelFgBrush}" Margin="0,0,0,5"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Save" Width="72" Margin="8,0,0,0"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="SaveApiKey_Click"/>
                            <PasswordBox x:Name="ApiKeyBox" PasswordChar="●"
                                         KeyDown="ApiKeyBox_KeyDown"/>
                        </DockPanel>
                    </StackPanel>

                    <!-- 상태 -->
                    <TextBlock Grid.Row="3" Grid.ColumnSpan="2"
                               x:Name="ApiKeyStatus" FontSize="11"
                               Foreground="{DynamicResource LabelFgBrush}" TextWrapping="Wrap"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── Startup ── -->
        <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="10"
                BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Margin="0,0,0,16" Padding="16,12">
            <StackPanel>
                <TextBlock Text="Startup" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource LabelFgBrush}" Margin="0,0,0,10"/>
                <CheckBox x:Name="RunAtStartupCheck"
                          Content="Launch Orbital when Windows starts"
                          Foreground="{DynamicResource TextMid}" FontSize="12"
                          Checked="RunAtStartupCheck_Changed"
                          Unchecked="RunAtStartupCheck_Changed"/>
            </StackPanel>
        </Border>

        <!-- ── Theme ── -->
        <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="10"
                BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Margin="0,0,0,16" Padding="16,12">
            <StackPanel>
                <TextBlock Text="Appearance" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource LabelFgBrush}" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Theme" FontSize="12" Foreground="{DynamicResource SubtitleFgBrush}"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox x:Name="ThemeBox" Width="180" SelectionChanged="ThemeBox_SelectionChanged">
                        <ComboBoxItem Content="Dark"              Tag="Dark"/>
                        <ComboBoxItem Content="Light"             Tag="Light"/>
                        <ComboBoxItem Content="System (follow Windows)" Tag="System"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Keyboard Shortcut ── -->
        <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="10"
                BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Margin="0,0,0,16" Padding="16,12">
            <StackPanel>
                <TextBlock Text="Keyboard Shortcut" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource LabelFgBrush}" Margin="0,0,0,10"/>
                <TextBlock FontSize="11" Foreground="{DynamicResource SubtitleFgBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,10">
                    Trigger the popup for the currently selected text using a hotkey.
                    Select modifiers, then click the key field and press a key.
                </TextBlock>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox x:Name="HotkeyCtrlCheck"  Content="Ctrl"  FontSize="12" Margin="0,0,10,0"
                              Foreground="{DynamicResource TextMid}"
                              Checked="Hotkey_Changed" Unchecked="Hotkey_Changed"/>
                    <CheckBox x:Name="HotkeyAltCheck"   Content="Alt"   FontSize="12" Margin="0,0,10,0"
                              Foreground="{DynamicResource TextMid}"
                              Checked="Hotkey_Changed" Unchecked="Hotkey_Changed"/>
                    <CheckBox x:Name="HotkeyShiftCheck" Content="Shift" FontSize="12" Margin="0,0,12,0"
                              Foreground="{DynamicResource TextMid}"
                              Checked="Hotkey_Changed" Unchecked="Hotkey_Changed"/>
                    <TextBlock Text="+" VerticalAlignment="Center"
                               Foreground="{DynamicResource SubtitleFgBrush}" Margin="0,0,12,0"/>
                    <TextBox x:Name="HotkeyKeyBox" Width="80" IsReadOnly="True"
                             TextAlignment="Center" VerticalContentAlignment="Center"
                             FontSize="12"
                             ToolTip="Click here, then press a key. Delete/Backspace to clear."
                             PreviewKeyDown="HotkeyKeyBox_PreviewKeyDown"
                             GotFocus="HotkeyKeyBox_GotFocus"
                             LostFocus="HotkeyKeyBox_LostFocus"/>
                    <Button Content="Clear" Width="56" Margin="8,0,0,0"
                            Click="HotkeyKey_Clear"/>
                </StackPanel>
                <TextBlock x:Name="HotkeyHint" FontSize="10" Margin="0,6,0,0"
                           Foreground="{DynamicResource TextLow}" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- ── Actions header ── -->
        <DockPanel Margin="0,0,0,8">
            <TextBlock Text="Actions" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource LabelFgBrush}" VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Import" Width="76" Margin="0,0,8,0"
                        Click="ImportActions_Click"/>
                <Button Content="Export" Width="76" Margin="0,0,8,0"
                        Click="ExportActions_Click"/>
                <Button Content="+ Add" Width="76"
                        Style="{StaticResource PrimaryButton}"
                        Click="AddAction_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- ── Actions list ── -->
        <ListView x:Name="ActionsList" SelectionMode="Single" MinHeight="150">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Icon" Width="40">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Icon}" 
                                           FontFamily="Segoe MDL2 Assets" 
                                           FontSize="13" 
                                           HorizontalAlignment="Center" 
                                           Foreground="{DynamicResource AccentBrush}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Name"   Width="95"  DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Prompt" Width="265" DisplayMemberBinding="{Binding PromptFormat}"/>
                    <GridViewColumn Header="Output" Width="98"  DisplayMemberBinding="{Binding ResultAction}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- ── Info & GitHub link ── -->
        <StackPanel Orientation="Vertical" Margin="0,10,0,0">
            <TextBlock FontSize="10" Foreground="{DynamicResource TextLow}" TextWrapping="Wrap"
                       Margin="0,0,0,4">
                Popup triggers: drag to select · double-click (word) · Shift+arrow keys / Ctrl+A · hold left button (≥ 300 ms) in a text field · custom hotkey above. Dismiss with Esc, right-click, or clicking outside.
            </TextBlock>
            <TextBlock FontSize="10">
                <Hyperlink NavigateUri="https://github.com/CrowKing63/Orbital"
                           RequestNavigate="Hyperlink_RequestNavigate">
                    GitHub — CrowKing63/Orbital
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        </StackPanel>
        </ScrollViewer>

        <!-- ── Bottom buttons ── -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Delete" Width="76" Margin="0,0,8,0"
                    Style="{StaticResource DangerButton}"
                    Click="DeleteAction_Click"/>
            <Button Content="Edit" Width="76" Margin="0,0,8,0"
                    Click="EditAction_Click"/>
            <Button Content="Save &amp; Close" Width="110"
                    Style="{StaticResource PrimaryButton}"
                    Click="SaveAndClose_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
