<Window x:Class="Orbit.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orbit 설정" Height="620" Width="640"
        Background="#0A0A18"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- 타이틀 -->
            <RowDefinition Height="Auto"/>
            <!-- API 설정 패널 -->
            <RowDefinition Height="Auto"/>
            <!-- 액션 헤더 -->
            <RowDefinition Height="Auto"/>
            <!-- 액션 리스트 -->
            <RowDefinition Height="*"/>
            <!-- 하단 버튼 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 타이틀 ── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,18">
            <Ellipse Width="10" Height="10" Margin="0,0,9,0" VerticalAlignment="Center">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#FF00D4FF" Offset="0"/>
                        <GradientStop Color="#FF7080FF" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <DropShadowEffect Color="#00D4FF" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/>
                </Ellipse.Effect>
            </Ellipse>
            <TextBlock Text="Orbit" FontSize="18" FontWeight="Bold"
                       Foreground="#8090FF" VerticalAlignment="Center"/>
            <TextBlock Text="  설정" FontSize="16" FontWeight="Light"
                       Foreground="#9898C8" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ── API 설정 패널 ── -->
        <Border Grid.Row="1" Background="#11112A" CornerRadius="10"
                BorderBrush="#28285A" BorderThickness="1" Margin="0,0,0,16" Padding="16,14">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="2" Opacity="0.3"/>
            </Border.Effect>
            <StackPanel>
                <!-- 섹션 헤더 -->
                <TextBlock Text="API 설정" FontSize="11" FontWeight="SemiBold"
                           Foreground="#5A5A90" Margin="0,0,0,12"/>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 제공자 -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,10">
                        <TextBlock Text="API 제공자" FontSize="11" Foreground="#5A5A90" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ProviderBox" SelectionChanged="ProviderBox_SelectionChanged">
                            <ComboBoxItem Tag="openai"     Content="OpenAI"/>
                            <ComboBoxItem Tag="openrouter" Content="OpenRouter"/>
                            <ComboBoxItem Tag="custom"     Content="사용자 지정"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- 모델 -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,10">
                        <TextBlock Text="모델" FontSize="11" Foreground="#5A5A90" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ModelBox" IsEditable="True" IsTextSearchEnabled="False"/>
                    </StackPanel>

                    <!-- Base URL -->
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,10">
                        <TextBlock Text="API Base URL" FontSize="11" Foreground="#5A5A90" Margin="0,0,0,5"/>
                        <TextBox x:Name="BaseUrlBox"/>
                    </StackPanel>

                    <!-- API 키 -->
                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,6">
                        <TextBlock Text="API 키" FontSize="11" Foreground="#5A5A90" Margin="0,0,0,5"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="저장" Width="72" Margin="8,0,0,0"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="SaveApiKey_Click"/>
                            <PasswordBox x:Name="ApiKeyBox" PasswordChar="●"
                                         KeyDown="ApiKeyBox_KeyDown"/>
                        </DockPanel>
                    </StackPanel>

                    <!-- 상태 -->
                    <TextBlock Grid.Row="3" Grid.ColumnSpan="2"
                               x:Name="ApiKeyStatus" FontSize="11"
                               Foreground="#5A5A90" TextWrapping="Wrap"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── 액션 버튼 헤더 ── -->
        <DockPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock Text="액션 버튼" FontSize="11" FontWeight="SemiBold"
                       Foreground="#5A5A90" VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right" Content="+ 추가" Width="76"
                    Style="{StaticResource PrimaryButton}"
                    Click="AddAction_Click"/>
        </DockPanel>

        <!-- ── 액션 리스트 ── -->
        <ListView Grid.Row="3" x:Name="ActionsList" SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="이름"     Width="95"  DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="프롬프트" Width="305" DisplayMemberBinding="{Binding PromptFormat}"/>
                    <GridViewColumn Header="출력 방식" Width="98" DisplayMemberBinding="{Binding ResultAction}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- ── 하단 버튼 ── -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="삭제" Width="76" Margin="0,0,8,0"
                    Style="{StaticResource DangerButton}"
                    Click="DeleteAction_Click"/>
            <Button Content="편집" Width="76" Margin="0,0,8,0"
                    Click="EditAction_Click"/>
            <Button Content="저장 및 닫기" Width="110"
                    Style="{StaticResource PrimaryButton}"
                    Click="SaveAndClose_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
