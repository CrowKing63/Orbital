<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Core design tokens ── -->
    <SolidColorBrush x:Key="BgDeep"    Color="#202020"/>
    <SolidColorBrush x:Key="BgPanel"   Color="#2A2A2A"/>
    <SolidColorBrush x:Key="BgElement" Color="#333333"/>
    <SolidColorBrush x:Key="BgHover"   Color="#3A3A3A"/>
    <SolidColorBrush x:Key="Border"    Color="#4A4A4A"/>
    <SolidColorBrush x:Key="AccentVi"  Color="#60A5FA"/>
    <SolidColorBrush x:Key="AccentCy"  Color="#93C5FD"/>
    <SolidColorBrush x:Key="TextHigh"  Color="#F3F3F3"/>
    <SolidColorBrush x:Key="TextMid"   Color="#D0D0D0"/>
    <SolidColorBrush x:Key="TextLow"   Color="#A0A0A0"/>
    <SolidColorBrush x:Key="Danger"    Color="#F87171"/>

    <!-- ── Settings window ── -->
    <SolidColorBrush x:Key="WindowBgBrush"      Color="#202020"/>
    <SolidColorBrush x:Key="PanelBgBrush"       Color="#2A2A2A"/>
    <SolidColorBrush x:Key="PanelBorderBrush"   Color="#4A4A4A"/>
    <SolidColorBrush x:Key="LabelFgBrush"       Color="#A0A0A0"/>
    <SolidColorBrush x:Key="TitleFgBrush"       Color="#F3F3F3"/>
    <SolidColorBrush x:Key="SubtitleFgBrush"    Color="#D0D0D0"/>
    <SolidColorBrush x:Key="AccentBrush"        Color="#60A5FA"/>

    <!-- ── Popup pill ── -->
    <SolidColorBrush x:Key="PillBgBrush"        Color="#D9303030"/>
    <SolidColorBrush x:Key="PillBorderBrush"    Color="#7060A5FA"/>
    <Color           x:Key="PillGlowColor">#60A5FA</Color>
    <Color           x:Key="AccentViColor">#60A5FA</Color>
    <Color           x:Key="AccentCyColor">#93C5FD</Color>
    <Color           x:Key="BgPanelColor">#2A2A2A</Color>

    <!-- ── Bar buttons ── -->
    <SolidColorBrush x:Key="BtnFgBrush"         Color="#EFEFEF"/>
    <SolidColorBrush x:Key="BtnHoverBgBrush"    Color="#3060A5FA"/>
    <SolidColorBrush x:Key="BtnPressedBgBrush"  Color="#4060A5FA"/>
    <SolidColorBrush x:Key="BtnHoverFgBrush"    Color="#93C5FD"/>
    <SolidColorBrush x:Key="BtnDisabledFgBrush" Color="#708A8A8A"/>

</ResourceDictionary>
