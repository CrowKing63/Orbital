<Window x:Class="Orbital.ResultTooltipWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orbital" SizeToContent="Height" Width="380"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <Border CornerRadius="14" Padding="0">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#EE0B0B22" Offset="0"/>
                <GradientStop Color="#EE0D0D2C" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.55" Color="#000010"/>
        </Border.Effect>
        <!-- 안쪽 테두리 (글래스 엣지) -->
        <Border CornerRadius="14" BorderBrush="#287080FF" BorderThickness="1">
            <StackPanel>

                <!-- 헤더 바 -->
                <Border Background="#18182E" CornerRadius="14,14,0,0" Padding="14,10">
                    <DockPanel>
                        <!-- 오르빗 아이콘 + 브랜드 -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" Margin="0,0,7,0">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#FF00D4FF" Offset="0"/>
                                        <GradientStop Color="#FF7080FF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#00D4FF" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="Orbital" Foreground="#8090FF" FontWeight="Bold"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 닫기 버튼 -->
                        <Button DockPanel.Dock="Right" Content="✕" Width="24" Height="24"
                                Cursor="Hand" Click="CloseButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"      Value="Transparent"/>
                                    <Setter Property="Foreground"      Value="#5A5A90"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FontSize"        Value="12"/>
                                    <Setter Property="Cursor"          Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                        CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF"/>
                                                        <Setter Property="Foreground" Value="#D0D0FF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </DockPanel>
                </Border>

                <!-- 구분선 -->
                <Rectangle Height="1">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#007080FF" Offset="0"/>
                            <GradientStop Color="#407080FF" Offset="0.4"/>
                            <GradientStop Color="#007080FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- 본문 -->
                <Border Padding="16,14,16,16">
                <StackPanel>
                    <TextBox x:Name="ResultText"
                             Foreground="#D8D8FF" Background="Transparent"
                             BorderThickness="0" IsReadOnly="True"
                             TextWrapping="Wrap" FontSize="13"
                             MaxHeight="320"
                             VerticalScrollBarVisibility="Auto"
                             SelectionBrush="#507080FF"
                             CaretBrush="Transparent"/>

                    <!-- 복사 버튼 -->
                    <Button Content="{DynamicResource Str_CopyToClipboard}" Margin="0,12,0,0"
                            HorizontalAlignment="Right" Click="CopyButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground"      Value="#9898C8"/>
                                <Setter Property="Background"      Value="#1E1E3A"/>
                                <Setter Property="BorderBrush"     Value="#28285A"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Padding"         Value="12,6"/>
                                <Setter Property="FontSize"        Value="11"/>
                                <Setter Property="Cursor"          Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="7"
                                                    Padding="{TemplateBinding Padding}">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#7080FF"/>
                                                        <ContentPresenter VerticalAlignment="Center"/>
                                                    </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"   Value="#252550"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush"  Value="#507080FF"/>
                                                    <Setter Property="Foreground" Value="#D0D0FF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
                </Border>

            </StackPanel>
        </Border>
    </Border>
</Window>
