<Window x:Class="Orbital.ResultTooltipWindow"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       Title="Orbital" SizeToContent="Height" Width="380"
       WindowStyle="None" AllowsTransparency="True" Background="Transparent"
       Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
       WindowStartupLocation="Manual">

    <Border CornerRadius="14" Padding="0"
            Background="{DynamicResource PillBgBrush}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.45" Color="#000000"/>
        </Border.Effect>
        <!-- Inner border (glass edge) -->
        <Border CornerRadius="14" BorderBrush="{DynamicResource PillBorderBrush}" BorderThickness="1">
            <StackPanel>

                <!-- Header bar -->
                <Border Background="{DynamicResource BgPanel}" CornerRadius="14,14,0,0" Padding="14,10">
                    <DockPanel>
                        <!-- Icon + brand -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" Margin="0,0,7,0">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="{DynamicResource AccentCyColor}" Offset="0"/>
                                        <GradientStop Color="{DynamicResource AccentViColor}" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="{DynamicResource AccentCyColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="Orbital" Foreground="{DynamicResource TitleFgBrush}" FontWeight="Bold"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Close button -->
                        <Button DockPanel.Dock="Right" Content="✕" Width="24" Height="24"
                                Cursor="Hand" Click="CloseButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"      Value="Transparent"/>
                                    <Setter Property="Foreground"      Value="{DynamicResource TextLow}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FontSize"        Value="12"/>
                                    <Setter Property="Cursor"          Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                        CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHover}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextHigh}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </DockPanel>
                </Border>

                <!-- Separator -->
                <Rectangle Height="1" Opacity="0.5">
                    <Rectangle.Fill>
                        <SolidColorBrush Color="{DynamicResource AccentViColor}"/>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Body -->
                <Border Padding="16,14,16,16">
                <StackPanel>
                    <TextBox x:Name="ResultText"
                             Foreground="{DynamicResource TextHigh}" Background="Transparent"
                             BorderThickness="0" IsReadOnly="True"
                             TextWrapping="Wrap" FontSize="13"
                             MaxHeight="320"
                             VerticalScrollBarVisibility="Auto"
                             SelectionBrush="{DynamicResource AccentVi}"
                             CaretBrush="Transparent"/>

                    <!-- Copy button -->
                    <Button Content="{DynamicResource Str_CopyToClipboard}" Margin="0,12,0,0"
                            HorizontalAlignment="Right" Click="CopyButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground"      Value="{DynamicResource TextMid}"/>
                                <Setter Property="Background"      Value="{DynamicResource BgElement}"/>
                                <Setter Property="BorderBrush"     Value="{DynamicResource Border}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Padding"         Value="12,6"/>
                                <Setter Property="FontSize"        Value="11"/>
                                <Setter Property="Cursor"          Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="7"
                                                    Padding="{TemplateBinding Padding}">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource AccentVi}"/>
                                                        <ContentPresenter VerticalAlignment="Center"/>
                                                    </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"  Value="{DynamicResource BgHover}"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentVi}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextHigh}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
                </Border>

            </StackPanel>
        </Border>
    </Border>
</Window>
