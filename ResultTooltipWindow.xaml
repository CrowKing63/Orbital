<Window x:Class="Orbit.ResultTooltipWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orbit" SizeToContent="Height" Width="360"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <Border Background="#E61a1a2e" CornerRadius="12" Padding="16"
            BorderBrush="#50FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5"/>
        </Border.Effect>
        <StackPanel>
            <!-- Header -->
            <DockPanel Margin="0,0,0,10">
                <TextBlock Text="Orbit" Foreground="#9090FF" FontWeight="Bold"
                           FontSize="12" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Content="✕" Width="22" Height="22"
                        Background="Transparent" Foreground="#AAAAAA" BorderThickness="0"
                        FontSize="12" Cursor="Hand" Click="CloseButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#AAAAAA"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#40FFFFFF"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </DockPanel>

            <!-- Result Text -->
            <TextBox x:Name="ResultText" Foreground="White" Background="Transparent"
                     BorderThickness="0" IsReadOnly="True" TextWrapping="Wrap"
                     FontSize="13" MaxHeight="300"
                     VerticalScrollBarVisibility="Auto" SelectionBrush="#609090FF"/>

            <!-- Copy button -->
            <Button Content="클립보드에 복사" Margin="0,10,0,0" Padding="8,4"
                    HorizontalAlignment="Right" Cursor="Hand" Click="CopyButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#40FFFFFF"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#60FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Border>
</Window>
